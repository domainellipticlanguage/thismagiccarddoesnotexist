# LLM Provider (groq or cerebras)
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Anthropic (for intent router eval)
ANTHROPIC_API_KEY=

# Art generation (Replicate)
REPLICATE_API_TOKEN=
# FLUX.2 klein output resolution; accepts 0.25, 0.5, 1, 2, 4
ART_MEGAPIXELS=1

# AWS resources
DYNAMODB_TABLE=thismagiccarddoesnotexist3
S3_BUCKET=thismagiccarddoesnotexist3

# Server
PORT=3001
# IS_DEBUG=true bypasses ALL ownership checks (anyone can edit/delete any card).
# Keep this false in any shared/deployed environment.
IS_DEBUG=false

FRIENDLI_API_KEY=