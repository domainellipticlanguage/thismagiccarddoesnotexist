{
  "name": "thismagiccarddoesnotexist3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "lsof -ti :3001 -ti :5173 2>/dev/null | xargs kill -9 2>/dev/null; concurrently -k -n api,web -c blue,green npm:dev:api npm:dev:web",
    "dev:api": "tsx watch server.ts",
    "dev:web": "npm run dev --prefix frontend",
    "link": "npm link mtg-crucible",
    "crucible": "npm install mtg-crucible@latest && npm install mtg-crucible@latest --prefix frontend",
    "build": "cd frontend && npm run build",
    "deploy": "npm run build && npx sst deploy --stage production",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.800.0",
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/lib-dynamodb": "^3.800.0",
    "@hono/node-server": "^1.13.0",
    "dotenv": "^16.5.0",
    "hono": "^4.6.0",
    "mtg-crucible": "^0.3.12",
    "openai": "^4.103.0",
    "replicate": "^1.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "@napi-rs/canvas-linux-arm64-gnu": "^0.1.97"
  }
}
